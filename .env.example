# =============================================================================
# TASS 시크릿 템플릿 (값 넣지 말고 .env.example 은 Git 에만 둡니다)
# 사용법: copy .env.example .env  →  .env 에만 실제 값 작성
# 읽는 코드: config/app_settings.py
# =============================================================================

# ── 기본 (개발 시작 시) ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
TIMEZONE=Asia/Seoul

# ── DB (Supabase / PostgreSQL 연결 시) ───────────────────────────────────────
DATABASE_URL=

# ── 캐시 (Redis / Upstash 연결 시) ───────────────────────────────────────────
REDIS_URL=

# ── API 보안 (REST API · Cron 보호 — 직접 생성, 32자 이상 권장) ─────────────
JWT_SECRET=
API_KEY=

# ── CORS (운영: 허용 Frontend origin, 쉼표 구분) ───────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Daily Pipeline 알림 (Slack/Discord Webhook URL) ──────────────────────────
WEBHOOK_URL=

# ── KIS (한국투자증권 Open API — 실시간 시세 전환 시) ────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# ── 참고: TASS 엔진 핵심에는 아래 불필요 (oho_bujaJJ 용) ─────────────────────
# DART_API_KEY=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
