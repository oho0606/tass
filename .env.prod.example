# =============================================================================
# TASS 클라우드 배포 환경변수 템플릿
# Render 대시보드 → Environment Variables 에서 입력하세요
# =============================================================================

LOG_LEVEL=WARNING
TIMEZONE=Asia/Seoul

# ── PostgreSQL (Supabase 무료 티어) ──────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Redis (Upstash 무료 티어) ─────────────────────────────────────────────────
# Upstash → Redis → Connect → .env
REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# ── API 보안 (Render가 자동 생성 — render.yaml의 generateValue: true) ─────────
JWT_SECRET=
API_KEY=

# ── CORS (Vercel 프론트엔드 URL) ──────────────────────────────────────────────
# 예: https://tass.vercel.app,https://tass-git-main-yourname.vercel.app
CORS_ORIGINS=https://your-app.vercel.app

# ── KIS (v1.1 실시간 전환 시) ─────────────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
