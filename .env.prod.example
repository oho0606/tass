# =============================================================================
# TASS Production Environment Template
# Usage: copy .env.prod.example .env  (on production server)
# =============================================================================

LOG_LEVEL=WARNING
TIMEZONE=Asia/Seoul

DATABASE_URL=postgresql://tass:CHANGE_ME@postgres:5432/tass
REDIS_URL=redis://redis:6379/0

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://your-domain.com

API_KEY=
JWT_SECRET=

# Slack or Discord incoming webhook (daily pipeline notifications)
WEBHOOK_URL=

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
